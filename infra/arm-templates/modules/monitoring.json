{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logAnalyticsName": { "type": "string" },
    "location": { "type": "string" },
    "dataFactoryId": { "type": "string" },
    "environment": { "type": "string" }
  },
  "variables": {
    "retentionMap": {
      "dev": 30,
      "staging": 60,
      "prod": 180
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[parameters('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": "[variables('retentionMap')[parameters('environment')]]"
      }
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "name": "[guid(parameters('dataFactoryId'), 'adf-diagnostics')]",
      "scope": "[parameters('dataFactoryId')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
      ],
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]",
        "logs": [
          { "category": "PipelineRuns", "enabled": true },
          { "category": "ActivityRuns", "enabled": true },
          { "category": "TriggerRuns", "enabled": true }
        ],
        "metrics": [
          { "category": "AllMetrics", "enabled": true }
        ]
      }
    }
  ],
  "outputs": {
    "logAnalyticsId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
    }
  }
}
