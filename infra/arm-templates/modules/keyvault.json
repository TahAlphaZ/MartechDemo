{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "keyVaultName": { "type": "string" },
    "location": { "type": "string" },
    "salesforceClientIdSecretName": { "type": "string", "defaultValue": "" },
    "salesforceClientSecretSecretName": { "type": "string", "defaultValue": "" },
    "salesforceUsernameSecretName": { "type": "string", "defaultValue": "" },
    "salesforcePasswordSecretName": { "type": "string", "defaultValue": "" },
    "salesforceTokenSecretName": { "type": "string", "defaultValue": "" }
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "enabledForTemplateDeployment": true,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        }
      }
    }
  ],
  "outputs": {
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(parameters('keyVaultName')).vaultUri]"
    },
    "keyVaultId": {
      "type": "string",
      "value": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
    },
    "salesforceClientIdSecretUri": {
      "type": "string",
      "value": "[if(equals(parameters('salesforceClientIdSecretName'), ''), '', concat(reference(parameters('keyVaultName')).vaultUri, 'secrets/', parameters('salesforceClientIdSecretName')))]"
    },
    "salesforceClientSecretSecretUri": {
      "type": "string",
      "value": "[if(equals(parameters('salesforceClientSecretSecretName'), ''), '', concat(reference(parameters('keyVaultName')).vaultUri, 'secrets/', parameters('salesforceClientSecretSecretName')))]"
    },
    "salesforceUsernameSecretUri": {
      "type": "string",
      "value": "[if(equals(parameters('salesforceUsernameSecretName'), ''), '', concat(reference(parameters('keyVaultName')).vaultUri, 'secrets/', parameters('salesforceUsernameSecretName')))]"
    },
    "salesforcePasswordSecretUri": {
      "type": "string",
      "value": "[if(equals(parameters('salesforcePasswordSecretName'), ''), '', concat(reference(parameters('keyVaultName')).vaultUri, 'secrets/', parameters('salesforcePasswordSecretName')))]"
    },
    "salesforceTokenSecretUri": {
      "type": "string",
      "value": "[if(equals(parameters('salesforceTokenSecretName'), ''), '', concat(reference(parameters('keyVaultName')).vaultUri, 'secrets/', parameters('salesforceTokenSecretName')))]"
    }
  }
}
